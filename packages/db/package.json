{
  "name": "@chaiforms/db",
  "version": "1.0.0",
  "description": "Database schema and utilities",
  "private": true,
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "migrate": "node --input-type=module --eval \"import('./src/migrate.ts')\"",
    "studio": "drizzle-kit studio",
    "seed": "node --input-type=module --eval \"import('./src/seed.ts')\"",
    "generate": "drizzle-kit generate:pg"
  },
  "dependencies": {
    "drizzle-orm": "^0.29.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.20.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
